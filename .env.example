# xbAI — local environment. Copy this file to `.env` and fill in YOUR values.
# `.env` is .gitignored and must never be committed. Scripts load it via Load-Env.ps1.

# ── Console (Xbox Series X in Developer Mode) ────────────────────────────────
# Hostname the console answers to on your LAN, and its IP (either works).
XBOX_HOST=XBOX
XBOX_IP=192.168.1.233
# Windows Device Portal port (HTTPS, self-signed cert).
WDP_PORT=11443

# ── Code signing (sideload cert) ─────────────────────────────────────────────
# Path (relative to repo root) to your self-signed .pfx, and its password.
# Generate your own with: New-SelfSignedCertificate ... then export to .pfx.
# The Publisher in the cert MUST match Package.appxmanifest <Identity Publisher="...">.
SIGNING_CERT_PFX=xbprobe/xbprobe/xbprobe_Key.pfx
SIGNING_CERT_PASSWORD=changeme

# ── Dev SMB push (optional fast path to stage a model onto the console) ───────
SMB_SHARE=\\XBOX\D$
SMB_USER=DevToolsUser
SMB_PASSWORD=changeme

# ── Model to fetch from Hugging Face (the ONNX/DirectML export to run) ────────
# Must already be an ORT-GenAI ONNX/DirectML export (we do not convert on-device).
HF_MODEL_REPO=microsoft/Phi-3-mini-4k-instruct-onnx
HF_MODEL_SUBDIR=directml/directml-int4-awq-block-128
